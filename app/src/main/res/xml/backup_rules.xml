<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude TTS model directory from backup to avoid large backup sizes -->
    <exclude domain="file" path="tts_models/" />
    <!-- Exclude external cache -->
    <exclude domain="external" path="cache/" />
    <!-- Exclude internal cache files -->
    <exclude domain="file" path="cache/" />
</full-backup-content>
