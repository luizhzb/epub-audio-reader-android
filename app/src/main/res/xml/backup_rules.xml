<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude TTS model directory from backup to avoid large backup sizes -->
    <exclude domain="file" path="tts_models/" />
    <!-- Exclude app cache -->
    <exclude domain="external" path="cache/" />
    <!-- Exclude internal cache -->
    <exclude domain="cache" path="." />
    <!-- Exclude internal no_backup directory -->
    <exclude domain="no_backup" path="." />
</full-backup-content>
